{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the workflow?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Missed call text back is an automated SMS that sends when your business misses an inbound call. The message usually acknowledges the missed call, identifies your business, and invites the caller to reply with what they need. The best workflows also route the reply, notify the right person, and log the conversation."
      }
    },
    {
      "@type": "Question",
      "name": "How quickly should a business text after a missed call?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The text should send as soon as the missed call is detected. The point is to respond while the caller still has intent. If your team waits until the next day, the message becomes a follow-up instead of a save. In our experience, the faster reply also makes the business feel more attentive."
      }
    },
    {
      "@type": "Question",
      "name": "Can AI qualify a lead by SMS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, AI can qualify a lead by SMS when the questions are clear and bounded. It can ask about service type, urgency, location, budget range, appointment preference, or current customer status. But your workflow should still define when a human takes over, especially for sensitive, angry, expensive, or unusual requests."
      }
    },
    {
      "@type": "Question",
      "name": "What should the first text say?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The first text should be short. Identify the business, acknowledge the missed call, ask what the caller needs, and set the next step. A useful example is: “Hi, this is [Business]. Sorry we missed your call. What can we help with today? Reply here and our team will follow up.”"
      }
    },
    {
      "@type": "Question",
      "name": "Is missed call text back compliant?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It can be, but compliance depends on message purpose, consent, opt-out handling, carrier rules, and local requirements. Keep the first message tied to the inbound call, identify your business, avoid promotional follow-up unless you have proper consent, and honor STOP requests. For formal legal advice, talk to counsel who understands SMS rules."
      }
    }
  ]
}