{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is AI web chat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AI web chat is a website chat tool that uses AI to answer visitor questions, collect intent, qualify leads, and route next steps. The best version does not only reply. It helps your business decide whether the visitor needs an answer, a booking path, SMS follow-up, or a human handoff."
      }
    },
    {
      "@type": "Question",
      "name": "How does web chat qualify leads?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Web chat qualifies leads by asking short, useful questions about need, urgency, fit, location, budget range, or timeline. The exact questions depend on your business. The rule is simple: ask only what your team needs to respond well. If the chat feels like a long form, you will lose the visitor."
      }
    },
    {
      "@type": "Question",
      "name": "Should AI chat connect to a CRM?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. If AI chat does not connect to a CRM or structured lead record, the conversation can get lost. At minimum, your system should capture the visitor’s question, contact details, source page, urgency, and next step. That gives your team context before the follow-up."
      }
    },
    {
      "@type": "Question",
      "name": "When should a person join the conversation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A person should join when the visitor is high-intent, upset, asking for custom pricing, dealing with a sensitive issue, or asking something the AI cannot answer with confidence. The AI should collect context and hand off cleanly. It should not fake judgment."
      }
    },
    {
      "@type": "Question",
      "name": "Can AI web chat replace a contact form?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sometimes. For many businesses, chat can reduce reliance on long forms because it captures intent in a more natural flow. But you may still need forms for formal requests, detailed intake, or compliance-heavy workflows. The better setup often uses both, with chat as the easier first path."
      }
    }
  ]
}
